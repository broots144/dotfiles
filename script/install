#!/usr/bin/env bash
#
# Run all dotfiles installers.

set -e

cd "$(dirname $0)"/..

setup_mas () {
  if ! command -v mas > /dev/null 2>&1
  then
    echo "installing mas"
    brew install mas
  fi

  # mas 7+ removed the `account` subcommand (Apple dropped the CLI sign-in API),
  # so we can neither verify nor trigger App Store sign-in from the CLI. The old
  # `until (mas account)` loop spins forever on modern mas, so branch on version.
  mas_major="$(mas version 2>/dev/null | cut -d. -f1)"

  if [ "${mas_major:-0}" -ge 7 ]
  then
    echo "Note: mas $(mas version) can't verify App Store sign-in from the CLI."
    echo "Make sure you're signed into the App Store app; mas installs are skipped if not."
    return 0
  fi

  # Older mas (<7): account check is supported. Wait for sign-in, but bounded so
  # an unattended run can never hang.
  if mas account > /dev/null 2>&1
  then
    echo "Signed into the Mac App Store as $(mas account)."
    return 0
  fi

  echo "You are not signed into the Mac App Store. Opening App Store now..."
  open -a "/Applications/App Store.app" || true

  for _ in $(seq 1 20)
  do
    if mas account > /dev/null 2>&1
    then
      echo "Signed into the Mac App Store as $(mas account)."
      return 0
    fi
    sleep 3
    echo "… waiting for Mac App Store sign-in …"
  done

  echo "Still not signed into the Mac App Store; continuing without mas sign-in."
}

# Setup MAS (https://github.com/mas-cli/mas)
setup_mas

# Run Homebrew through the Brewfile
echo "› brew bundle"
brew bundle

# find the installers and run them iteratively
find . -name install.sh | while read installer ; do sh -c "${installer}" ; done
